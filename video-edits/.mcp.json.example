{
  "mcpServers": {
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "YOUR_BRAVE_API_KEY_HERE"
      }
    },
    "pexels": {
      "command": "uvx",
      "args": ["mcp-server-pexels"],
      "env": {
        "PEXELS_API_KEY": "YOUR_PEXELS_API_KEY_HERE"
      }
    },
    "pixabay": {
      "command": "uvx",
      "args": ["mcp-pixabay"],
      "env": {
        "PIXABAY_API_KEY": "YOUR_PIXABAY_API_KEY_HERE"
      }
    }
  }
}
